{
  "name": "quick-trim",
  "version": "1.0.0",
  "description": "极简无损视频裁剪工具 (Quick Trim)",
  "main": "src/main.js",
  "author": "",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder",
    "dist:win": "electron-builder --win",
    "dist:mac": "electron-builder --mac"
  },
  "dependencies": {
    "ffmpeg-static": "^5.2.0",
    "ffprobe-static": "^3.1.0"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.quicktrim.app",
    "productName": "Quick Trim",
    "files": [
      "src/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "**/node_modules/ffmpeg-static/**",
      "**/node_modules/ffprobe-static/**"
    ],
    "fileAssociations": [
      { "ext": "mp4", "name": "MP4 Video", "role": "Viewer" },
      { "ext": "mov", "name": "QuickTime Movie", "role": "Viewer" },
      { "ext": "mkv", "name": "Matroska Video", "role": "Viewer" },
      { "ext": "m4v", "name": "M4V Video", "role": "Viewer" },
      { "ext": "avi", "name": "AVI Video", "role": "Viewer" },
      { "ext": "webm", "name": "WebM Video", "role": "Viewer" },
      { "ext": "ts", "name": "MPEG-TS Video", "role": "Viewer" },
      { "ext": "flv", "name": "Flash Video", "role": "Viewer" },
      { "ext": "wmv", "name": "Windows Media Video", "role": "Viewer" }
    ],
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg",
      "category": "public.app-category.video"
    },
    "linux": {
      "target": "AppImage",
      "category": "AudioVideo"
    }
  }
}
