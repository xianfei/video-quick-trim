{
  "name": "quick-trim",
  "version": "1.3.0",
  "description": "极简无损视频裁剪工具 (Quick Trim)",
  "main": "electron/main.js",
  "author": "",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder",
    "dist:win": "electron-builder --win",
    "dist:mac": "electron-builder --mac",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build"
  },
  "dependencies": {
    "ffmpeg-static": "^5.2.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.11.3",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.quicktrim.app",
    "productName": "Quick Trim",
    "files": [
      "electron/**/*",
      "ui/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "**/node_modules/ffmpeg-static/**"
    ],
    "fileAssociations": [
      {
        "ext": "mp4",
        "name": "MP4 Video",
        "role": "Viewer"
      },
      {
        "ext": "mov",
        "name": "QuickTime Movie",
        "role": "Viewer"
      },
      {
        "ext": "mkv",
        "name": "Matroska Video",
        "role": "Viewer"
      },
      {
        "ext": "m4v",
        "name": "M4V Video",
        "role": "Viewer"
      },
      {
        "ext": "avi",
        "name": "AVI Video",
        "role": "Viewer"
      },
      {
        "ext": "webm",
        "name": "WebM Video",
        "role": "Viewer"
      },
      {
        "ext": "ts",
        "name": "MPEG-TS Video",
        "role": "Viewer"
      },
      {
        "ext": "flv",
        "name": "Flash Video",
        "role": "Viewer"
      },
      {
        "ext": "wmv",
        "name": "Windows Media Video",
        "role": "Viewer"
      }
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": true,
      "artifactName": "${productName}-${version}-setup.${ext}"
    },
    "portable": {
      "artifactName": "${productName}-${version}-portable.${ext}"
    },
    "mac": {
      "target": "dmg",
      "category": "public.app-category.video"
    },
    "linux": {
      "target": "AppImage",
      "category": "AudioVideo"
    }
  }
}
